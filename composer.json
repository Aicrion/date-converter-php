{
    "name": "aicrion/date-converter",
    "description": "High-performance PHP library for converting between Gregorian, Jalali (Persian) and Hijri (Islamic) calendars.",
    "keywords": ["date", "calendar", "jalali", "persian", "shamsi", "hijri", "islamic", "gregorian", "converter"],
    "type": "library",
    "homepage": "https://github.com/aicrion/date-converter-php",
    "license": "MIT",
    "authors": [
        {
            "name": "Hadi Akbarzadeh",
            "email": "elsiomcoder@gmail.com",
            "homepage": "https://elatel.ir",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Aicrion\\DateConverter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aicrion\\DateConverter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always"
    },
    "require": {
        "php": ">=8.2",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "stable"
}
